{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Night Shift Run Event",
  "description": "Structured report emitted after every Night Shift run.",
  "type": "object",
  "required": ["repo", "timestamp", "run_url", "backend", "bundles", "duration_seconds", "model"],
  "properties": {
    "repo": {
      "type": "string",
      "description": "GitHub repository in owner/name format.",
      "pattern": "^[^/]+/[^/]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the run completed."
    },
    "run_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to the GitHub Actions run."
    },
    "backend": {
      "type": "string",
      "enum": ["github-actions"],
      "description": "Execution backend that ran Night Shift."
    },
    "bundles": {
      "type": "object",
      "description": "Per-bundle results.",
      "properties": {
        "plans":      { "$ref": "#/$defs/bundleResult" },
        "docs":       { "$ref": "#/$defs/bundleResult" },
        "code-fixes": { "$ref": "#/$defs/bundleResult" },
        "audits":     { "$ref": "#/$defs/bundleResult" }
      },
      "additionalProperties": { "$ref": "#/$defs/bundleResult" }
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Wall-clock duration of the run in seconds."
    },
    "model": {
      "type": "string",
      "description": "Claude model used for the run."
    }
  },
  "$defs": {
    "bundleResult": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ok", "silent", "skipped", "failed", "unknown"],
          "description": "Outcome of the bundle."
        },
        "prs": {
          "type": "array",
          "items": { "type": "string", "format": "uri" },
          "default": [],
          "description": "URLs of pull requests opened by this bundle."
        },
        "commits": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of commits made by this bundle."
        }
      }
    }
  }
}
